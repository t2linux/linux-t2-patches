+static void macsmc_power_acpi_work(struct work_struct *work)
+{
+	struct macsmc_power *power = container_of(to_delayed_work(work),
+			struct macsmc_power, poll_work);
+	u8 bncr;
+
+	if (apple_smc_read_u8(power->smc, SMC_KEY(BNCR), &bncr) == 0 && power->old_bncr != bncr) {
+		power_supply_changed(power->batt);
+		power_supply_changed(power->ac);
+		power->old_bncr = bncr;
+	}
+
+	schedule_delayed_work(&power->poll_work, HZ);
+}
