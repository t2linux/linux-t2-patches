+	       !amdgpu_sriov_vf(adev);
+}
+
+static void amdgpu_device_clear_ip_hw_status(struct amdgpu_device *adev)
+{
+	int i;
+
+	for (i = 0; i < adev->num_ip_blocks; i++) {
+		if (!adev->ip_blocks[i].status.valid)
+			continue;
+
+		adev->ip_blocks[i].status.hw = false;
+	}
+}
+
+static int amdgpu_device_t2_retry_init(struct amdgpu_device *adev)
+{
+	int r;
+
+	if (adev->t2_smu_init_retry)
+		return -ETIMEDOUT;
+
+	adev->t2_smu_init_retry = true;
+
+	dev_warn(adev->dev,
+		 "Apple T2 SMU init timeout detected, retrying full IP init after ASIC reset\n");
+
+	amdgpu_device_ip_fini(adev);
+
+	amdgpu_device_lock_reset_domain(adev->reset_domain);
+	r = amdgpu_asic_reset(adev);
+	amdgpu_device_unlock_reset_domain(adev->reset_domain);
+	if (r) {
+		dev_err(adev->dev,
+			"Apple T2 SMU init recovery ASIC reset failed %d\n", r);
+		return r;
+	}
+
+	return amdgpu_device_ip_init(adev);
+}
+
+static int amdgpu_device_t2_retry_resume(struct amdgpu_device *adev)
+{
+	int r;
+
+	if (adev->t2_smu_resume_retry)
+		return -ETIMEDOUT;
+
+	adev->t2_smu_resume_retry = true;
+
+	dev_warn(adev->dev,
+		 "Apple T2 SMU resume timeout detected, retrying resume after ASIC reset\n");
+
+	amdgpu_device_lock_reset_domain(adev->reset_domain);
+	r = amdgpu_asic_reset(adev);
+	amdgpu_device_unlock_reset_domain(adev->reset_domain);
+	if (r) {
+		dev_err(adev->dev,
+			"Apple T2 SMU resume recovery ASIC reset failed %d\n", r);
+		return r;
+	}
+
+	amdgpu_device_clear_ip_hw_status(adev);
+
+	return amdgpu_device_ip_resume(adev);
+}
